{
  "name": "git-summary-mcp",
  "version": "0.1.0",
  "description": "MCP server for local Git repository intelligence — commit summaries, changelogs, blame analysis, branch health, and semantic diffs",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "git-summary-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "git",
    "git-log",
    "changelog",
    "git-blame",
    "git-diff",
    "developer-tools",
    "ai-tools",
    "claude",
    "cursor",
    "windsurf"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yifanyifan897645/git-summary-mcp"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
